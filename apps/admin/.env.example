# Backend API base URL. Copy to .env.local — do not commit .env.local
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:38472
# Production example:
# NEXT_PUBLIC_API_URL=https://api.funt.in

# Invoice issuer (shown on printed invoices — match backend INVOICE_ISSUER_*)
# NEXT_PUBLIC_INVOICE_ISSUER_LEGAL_NAME=FUNT Robotics Academy
# NEXT_PUBLIC_INVOICE_ISSUER_SIGNED_BY=FUNT Robotics Academy
# NEXT_PUBLIC_INVOICE_ISSUER_ADDRESS=Your registered address
# NEXT_PUBLIC_INVOICE_ISSUER_GSTIN=
# NEXT_PUBLIC_INVOICE_ISSUER_PAN=
# NEXT_PUBLIC_INVOICE_ISSUER_STATE=Telangana
# NEXT_PUBLIC_INVOICE_ISSUER_EMAIL=
# NEXT_PUBLIC_INVOICE_ISSUER_PHONE=
