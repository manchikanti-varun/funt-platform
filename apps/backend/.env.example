PORT=38472

# Local work: use development (or omit — defaults to development). Use production only when
# deploying; do not set NODE_ENV=production on your laptop unless you are deliberately testing prod behavior.
NODE_ENV=development

# MongoDB Atlas (replace with your own URI)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/funt_lms?retryWrites=true&w=majority

# Redis (optional) — enables shared rate-limit store + application caching (auth, courses, explore).
# Supports Upstash (free tier works). If omitted, rate limiting uses in-memory and caching is disabled.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:YOUR_TOKEN@your-instance.upstash.io:6379

# JWT auth — use a long random secret (production requires >= 32 chars; see apps/backend/src/config/env.ts)
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
# Portal-specific session lifetime (recommended defaults)
JWT_EXPIRES_IN_ADMIN=8h
JWT_EXPIRES_IN_LMS=12h
# Idle timeout (minutes): users must re-login after inactivity
IDLE_TIMEOUT_MINUTES_ADMIN=180
IDLE_TIMEOUT_MINUTES_LMS=45

# Public URL of this backend
BACKEND_PUBLIC_URL=http://localhost:38472

# Allowed frontend origins (comma-separated, no trailing slash)
# Example production: https://admin.example.com,https://lms.example.com
# If NODE_ENV=production locally, add CORS_ALLOW_LOCALHOST=1 so http://localhost:3000 / 3001 work.
CORS_ORIGINS=
# CORS_ALLOW_LOCALHOST=1

# Frontend URLs (used for redirects / CORS defaults)
# Dev defaults:
FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_LMS_URL=http://localhost:3001
# Production values (set these in your deployment env):
# FRONTEND_ADMIN_URL=https://admin.funt.in
# FRONTEND_LMS_URL=https://learn.funt.in

# Google OAuth (optional)
# Redirect URI must match Google Cloud Console exactly: {BACKEND_PUBLIC_URL}/api/auth/google/callback
# (same host as BACKEND_PUBLIC_URL — localhost vs 127.0.0.1 and port must match). While the API is
# running, open GET /api/auth/google/redirect-uri for the exact string to paste into Console.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Super Admin — optional; used only by: npm run seed:super-admin (when no Super Admin exists yet)
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password
# SUPER_ADMIN_NAME=Super Admin

# Safety flag for destructive reset scripts (keep 0 in normal use)
RESET_CONFIRM=0

# --- Local dev accounts (password: set DEV_LOGIN_PASSWORD only; never hardcode in code) ---
# Creates three users (same password): Super Admin, Admin, Student — fixed emails/usernames in devLocalAccounts.ts
#   Super Admin: dev.superadmin@local.test
#   Admin:       dev.admin@local.test
#   Student:     username dev.student / dev.student@local.test
# Add users if missing:
#   DEV_LOGIN_SEED_CONFIRM=1 npm run seed:dev-logins
# Wipe entire DB then seed (destructive):
#   CONFIRM_DROP_DB_AND_RESEED=DROP_ALL_DATA_AND_RESEED npm run db:reset-dev
# Delete all users then seed (destructive for User collection only):
#   CONFIRM_DELETE_ALL_USERS_AND_RESEED=DELETE_ALL_USERS_AND_RESEED npm run db:reset-users-dev
DEV_LOGIN_PASSWORD=

# Deploying (hosted URLs, CORS, etc.): see README.md § Production deployment.

# --- Student course checkout (optional) ---
# Platform receiving UPI used for manual UPI (QR + UTR) flows.
# If these are missing, Super Admin must configure UPI in Admin > UPI & QR center.
# PAYMENT_UPI_ID=your-upi-id@bank
# PAYMENT_UPI_NAME=Legal Receiver Name
# Static UPI QR image URL shown on LMS payment page (UPI tab)
# PAYMENT_UPI_QR_URL=https://your-cdn.example.com/upi-qr.png
# Razorpay (https://dashboard.razorpay.com/) — used for “Card / UPI app” checkout; keys stay on server only
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=your_secret

# Electronic invoice (integrity signing — use a dedicated secret in production)
# INVOICE_SIGNING_SECRET=long-random-secret-min-32-chars
# INVOICE_ISSUER_LEGAL_NAME=FUNT Robotics Academy
# INVOICE_ISSUER_SIGNED_BY=FUNT Robotics Academy
# INVOICE_ISSUER_ADDRESS=Registered office address
# INVOICE_ISSUER_GSTIN=
# INVOICE_ISSUER_PAN=
# INVOICE_ISSUER_STATE=Telangana
# INVOICE_ISSUER_EMAIL=
# INVOICE_ISSUER_PHONE=

# --- Cloudflare R2 Video Storage ---
# Required for MP4 video uploads. Find these in the Cloudflare dashboard:
#   R2 > Manage API Tokens  →  R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
#   Account Home            →  R2_ACCOUNT_ID (from URL: dash.cloudflare.com/<account_id>)
#
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET=funt
# R2_ENDPOINT= (optional — auto-derived from R2_ACCOUNT_ID when blank)
#
# Upload architecture: direct browser → R2 via presigned PUT URLs.
# Railway only issues the URL and confirms the upload afterward.
# Railway never buffers video bytes — no memory or bandwidth limits apply.
#
# Videos are stored as: courses/{courseId}/{moduleId}/{lessonId}.mp4
# Students receive short-lived presigned GET URLs (5 min) — never permanent links.
#
# R2 CORS (required for direct browser uploads):
# In Cloudflare dashboard → R2 → your bucket → Settings → CORS Policy, add:
#   [{"AllowedOrigins":["https://admin.funt.in","http://localhost:3000"],
#     "AllowedMethods":["PUT"],"AllowedHeaders":["Content-Type"],"MaxAgeSeconds":3600}]
