# Server (high port 38472 avoids conflict; set NEXT_PUBLIC_API_URL in admin/lms to match)
PORT=38472

# Production: set to production so CORS, rate limits, and error responses are hardened.
NODE_ENV=development

# MongoDB Atlas
# Get your URI from: Atlas → Cluster → Connect → Drivers → Node.js
# Replace CLUSTER_SUFFIX with your cluster ID (e.g. cluster0.abc12.mongodb.net → use abc12)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.CLUSTER_SUFFIX.mongodb.net/funt_lms?retryWrites=true&w=majority

# Auth (required). Production: use a long random secret (e.g. openssl rand -base64 32).
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Production only: comma-separated allowed origins (no trailing slashes).
# Example: https://admin.example.com,https://lms.example.com
# CORS_ORIGINS=

# Google OAuth (optional).
# In Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID:
# Add this EXACT "Authorized redirect URI" (backend URL, not frontend):
#   http://localhost:38472/api/auth/google/callback
# For production, add: https://your-api-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Base URL of this backend (for OAuth redirect). Production: e.g. https://api.example.com
BACKEND_PUBLIC_URL=

# Frontend URLs for OAuth redirect after login (optional, defaults below)
FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_LMS_URL=http://localhost:3001

# Super Admin (for seed:super-admin and reset:and-seed)
# Required: email, password. Optional: name, mobile (defaults below).
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password
# SUPER_ADMIN_NAME=Super Admin
# SUPER_ADMIN_MOBILE=+910000000000
