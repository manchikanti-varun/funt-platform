PORT=38472
NODE_ENV=development

# MongoDB Atlas (replace with your own URI)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/funt_lms?retryWrites=true&w=majority

# JWT auth (use a strong random secret in real .env)
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Public URL of this backend
BACKEND_PUBLIC_URL=http://localhost:38473

# Allowed frontend origins (comma-separated, no trailing slash)
# Example production: https://admin.example.com,https://lms.example.com
CORS_ORIGINS=

# Frontend URLs (used for redirects / CORS defaults)
FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_LMS_URL=http://localhost:3001

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Super Admin (used by seed/reset scripts only)
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password
# SUPER_ADMIN_NAME=Super Admin

# Safety flag for destructive reset scripts (keep 0 in normal use)
RESET_CONFIRM=0

# --- Production (Railway) ---
# Do NOT set PORT on Railway (platform sets it). Use the block below in Railway Variables.
# NODE_ENV=production
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/funt_lms?retryWrites=true&w=majority
# JWT_SECRET=<64-char-hex-or-long-random-string>
# JWT_EXPIRES_IN=7d
# BACKEND_PUBLIC_URL=https://your-backend.up.railway.app
# FRONTEND_ADMIN_URL=https://your-admin.vercel.app
# FRONTEND_LMS_URL=https://your-lms.vercel.app
# CORS_ORIGINS=https://your-admin.vercel.app,https://your-lms.vercel.app
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
